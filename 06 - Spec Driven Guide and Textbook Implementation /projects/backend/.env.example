# Backend environment variables
# Copy to .env and fill in your values

# ===========================================
# Database (Neon Postgres)
# ===========================================
DATABASE_URL="postgresql://user:password@host.neon.tech/textbook?schema=public"

# ===========================================
# Vector Store (Qdrant Cloud)
# ===========================================
QDRANT_URL="https://your-qdrant-cluster.qdrant.cloud"
QDRANT_API_KEY="your-qdrant-api-key"

# ===========================================
# AI/LLM Configuration (LiteLLM)
# ===========================================
# Use LiteLLM to proxy multiple LLM providers
# Supported: openai, anthropic, gemini, azure, etc.
LITELLM_MODEL="gemini/gemini-2.0-flash"
LITELLM_API_KEY="your-gemini-api-key"
LITELLM_BASE_URL="https://api.gemini.com/v1"  # Optional: for proxy setup

# ===========================================
# Embeddings (sentence-transformers)
# ===========================================
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# ===========================================
# Authentication
# ===========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_SECRET="your-auth-secret-min-32-chars"

# ===========================================
# CORS
# ===========================================
ALLOWED_ORIGINS="http://localhost:3000,https://your-project.vercel.app"

# ===========================================
# Optional: Feature Flags
# ===========================================
# ENABLE_QUIZ_GENERATION=true
# ENABLE_SUMMARIES=true